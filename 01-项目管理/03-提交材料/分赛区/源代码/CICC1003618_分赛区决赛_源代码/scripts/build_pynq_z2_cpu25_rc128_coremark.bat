@echo off
setlocal

for %%I in ("%~dp0..") do set PROJECT_DIR=%%~fI
set MODE=%~1
if "%MODE%"=="" set MODE=impl

set COREMARK_TARGET=rv32i_zmmul_zba_zbb_zbs_zbc_zicond_zbkb_xthead_memidx_mac_noautoinc_o2sched_nocaller
set COREMARK_OUTPUT=YH_rv_cpu_coremark_cpu25_rc128

echo === Build CPU25 RC128 CoreMark firmware ===
call "%~dp0build_coremark.bat" %COREMARK_TARGET% 10 2000 100000000UL 0 %COREMARK_OUTPUT%
if errorlevel 1 exit /b 1

set ROM_INIT_HEX_OVERRIDE=%PROJECT_DIR%\build\sw\%COREMARK_OUTPUT%.hex
set ROM_INIT_MEM32_HEX_OVERRIDE=%PROJECT_DIR%\build\sw\%COREMARK_OUTPUT%.mem32.hex
set RAM_BASE_OVERRIDE=32'h00010000
set ROM_BYTES_OVERRIDE=65536
set RAM_BYTES_OVERRIDE=16384

set PYNQ_INPUT_CLOCK_PERIOD_NS_OVERRIDE=8.000
set PYNQ_SYNTH_RETIMING_OVERRIDE=0
set PYNQ_SYNTH_NO_TIMING_DRIVEN_OVERRIDE=1
set PYNQ_QUICK_UTIL_ONLY_OVERRIDE=0
set PYNQ_CPU_CLK_FREQ_HZ_OVERRIDE=25000000
set PYNQ_USE_CLK_MMCM_25M_OVERRIDE=1
set PYNQ_USE_CLK_MMCM_62M5_OVERRIDE=0
set PYNQ_USE_CLK_MMCM_50M_OVERRIDE=0

set PYNQ_ENABLE_M_EXTENSION_OVERRIDE=0
set PYNQ_ENABLE_ZMMUL_EXTENSION_OVERRIDE=1
set PYNQ_ENABLE_BITMANIP_EXTENSION_OVERRIDE=1
set PYNQ_ENABLE_ZBC_EXTENSION_OVERRIDE=1
set PYNQ_ENABLE_ZICOND_EXTENSION_OVERRIDE=1
set PYNQ_ENABLE_ZBKB_EXTENSION_OVERRIDE=1
set PYNQ_ENABLE_XTHEAD_EXTENSION_OVERRIDE=1
set PYNQ_ENABLE_XTHEAD_CRC_EXTENSION_OVERRIDE=0
set PYNQ_ENABLE_XTHEAD_MUL_EXTENSION_OVERRIDE=1
set PYNQ_ENABLE_XTHEAD_COND_MOVE_OVERRIDE=1
set PYNQ_ENABLE_XTHEAD_ADDSL_EXTENSION_OVERRIDE=0
set PYNQ_ENABLE_XTHEAD_MEMPAIR_EXTENSION_OVERRIDE=0
set PYNQ_ENABLE_XTHEAD_BASE_UPDATE_EXTENSION_OVERRIDE=0

set PYNQ_ENABLE_ID_BRANCH_EX_FORWARD_OVERRIDE=0
set PYNQ_ENABLE_ID_BRANCH_EXMEM_LOAD_FORWARD_OVERRIDE=1
set PYNQ_ENABLE_EX_REDIRECT_EXMEM_LOAD_FORWARD_OVERRIDE=1
set PYNQ_ENABLE_ID_BRANCH_FOLD_OVERRIDE=1
set PYNQ_ENABLE_ID_BRANCH_FOLD_NEXT_CACHE_OVERRIDE=0
set PYNQ_ENABLE_EX_REDIRECT_FOLD_OVERRIDE=1
set PYNQ_ENABLE_ID_BRANCH_NT_NEXT_CACHE_OVERRIDE=1
set PYNQ_ENABLE_ID_BRANCH_NOT_TAKEN_LOAD_FOLD_OVERRIDE=1
set PYNQ_ENABLE_ID_ALU_PAIR_FOLD_OVERRIDE=0
set PYNQ_ENABLE_ID_ALU_DEP_FOLD_OVERRIDE=0

set PYNQ_ENABLE_REDIRECT_TARGET_CACHE_OVERRIDE=1
set PYNQ_ENABLE_REDIRECT_CACHE_REGULAR_LOOKUP_OVERRIDE=1
set PYNQ_ENABLE_FETCH_REDIRECT_REUSE_OVERRIDE=0
set PYNQ_REDIRECT_CACHE_ENTRIES_OVERRIDE=128
set PYNQ_REDIRECT_CACHE_XOR_INDEX_OVERRIDE=0
set PYNQ_ENABLE_DYNAMIC_BRANCH_PREDICT_OVERRIDE=0
set PYNQ_BRANCH_BHT_ENTRIES_OVERRIDE=2
set PYNQ_BRANCH_STATIC_PREDICT_MODE_OVERRIDE=0

set PYNQ_DMEM_NEGEDGE_READ_OVERRIDE=0
set PYNQ_DMEM_READ_PREISSUE_OVERRIDE=0
set PYNQ_DCACHE_EN_OVERRIDE=1
set PYNQ_DCACHE_SIZE_BYTES_OVERRIDE=512
set PYNQ_ENABLE_DCACHE_LOAD_USE_SPEC_OVERRIDE=1
set PYNQ_ENABLE_CONTROL_REDIRECT_DCACHE_LOAD_USE_SPEC_OVERRIDE=1
set PYNQ_ENABLE_BRANCH_REDIRECT_DCACHE_LOAD_USE_SPEC_OVERRIDE=1
set PYNQ_ENABLE_JALR_REDIRECT_DCACHE_LOAD_USE_SPEC_OVERRIDE=0
set PYNQ_ENABLE_FRONTEND_DCACHE_LOAD_USE_SPEC_OVERRIDE=0
set PYNQ_ENABLE_FOLD_DCACHE_LOAD_USE_SPEC_OVERRIDE=0
set PYNQ_ENABLE_FOLD_EXMEM_LOAD_USE_SPEC_OVERRIDE=1
set PYNQ_ENABLE_DCACHE_NEXT_PREFETCH_OVERRIDE=0
set PYNQ_ENABLE_DCACHE_WORD_ONLY_OVERRIDE=0
set PYNQ_ICACHE_EN_OVERRIDE=0

echo === PYNQ-Z2 CPU25 RC128 CoreMark %MODE% ===
call "%~dp0build_pynq_z2_project.bat" %MODE%
exit /b %ERRORLEVEL%
