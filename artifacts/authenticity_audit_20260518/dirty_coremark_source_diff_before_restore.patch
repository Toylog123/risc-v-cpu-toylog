+#define CORE_LIST_NEXT(item, reversed) ((reversed) ? (item)->prev : (item)->next)
+#define CORE_LIST_PREV(item, reversed) ((reversed) ? (item)->next : (item)->prev)
+#define CORE_LIST_SET_NEXT(item, reversed, value) \
+    do                                           \
+    {                                            \
+        if (reversed)                            \
+            (item)->prev = (value);              \
+        else                                     \
+            (item)->next = (value);              \
+    } while (0)
+#define CORE_LIST_SET_PREV(item, reversed, value) \
+    do                                           \
+    {                                            \
+        if (reversed)                            \
+            (item)->next = (value);              \
+        else                                     \
+            (item)->prev = (value);              \
+    } while (0)
+
+static list_head *core_cached_prev_head = NULL;
+static list_head *core_cached_prev_tail = NULL;
+
+static ee_u16
+core_list_crc16_fast(ee_s16 newval, ee_u16 crc)
+{
+#if defined(YH_COREMARK_CUSTOM_CRC16)
+    ee_u32 result;
+    __asm__ volatile(".insn r 0x0b, 0x0, 40, %0, %1, %2"
+                     : "=r"(result)
+                     : "r"((ee_u32)((ee_u16)newval)), "r"((ee_u32)crc));
+    return (ee_u16)result;
+#else
+    return crc16(newval, crc);
+#endif
+}
+
+static list_head *
+core_list_rebuild_prev(list_head *list, list_head **tail_out)
+{
+    list_head *prev = NULL;
+    list_head *cur  = list;
+    while (cur)
+    {
+        cur->prev = prev;
+        prev      = cur;
+        cur       = cur->next;
+    }
+    if (tail_out)
+        *tail_out = prev;
+    core_cached_prev_head = list;
+    core_cached_prev_tail = prev;
+    return list;
+}
