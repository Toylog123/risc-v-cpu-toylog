+#endif
 }
 ee_u16
 crcu32(ee_u32 newval, ee_u16 crc)
 {
+#if defined(YH_COREMARK_CUSTOM_CRC32)
+    ee_u32 result;
+    __asm__ volatile(".insn r 0x0b, 0x0, 41, %0, %1, %2"
+                     : "=r"(result)
+                     : "r"(newval), "r"((ee_u32)crc));
+    return (ee_u16)result;
+#else
     crc = crc16((ee_s16)newval, crc);
     crc = crc16((ee_s16)(newval >> 16), crc);
     return crc;
+#endif
 }
 ee_u16
 crc16(ee_s16 newval, ee_u16 crc)
 {
+#if defined(YH_COREMARK_CUSTOM_CRC16)
